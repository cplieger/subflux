{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["app.ts", "login.ts", "**/*.test.ts"],
  "ignore": ["wire/*.gen.ts"],
  "project": ["**/*.ts", "!**/*.d.ts", "!node_modules/**"],
  "ignoreDependencies": ["html-validate", "stylelint", "stylelint-config-standard"],
  "ignoreBinaries": [],
  "ignoreMembers": [],
  "treatConfigHintsAsErrors": true,
  "includeEntryExports": true,
  "typescript": {
    "config": ["tsconfig.json"]
  }
}
