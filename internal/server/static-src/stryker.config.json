{
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "typescriptChecker": {
    "prioritizePerformanceOverAccuracy": false
  },
  "mutate": [
    "api-client.ts",
    "config.ts",
    "config-yaml.ts",
    "coverage.ts",
    "detail.ts",
    "dom.ts",
    "error_codes.ts",
    "events.ts",
    "files.ts",
    "history.ts",
    "notify.ts",
    "search.ts",
    "security.ts",
    "skeleton-timing.ts",
    "status.ts",
    "store.ts",
    "sync-timecode.ts",
    "theme.ts",
    "utils.ts",
    "validators.ts"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "ignorePatterns": ["node_modules", "reports", "coverage", "dist"],
  "ignoreStatic": true,
  "reporters": ["html", "progress", "clear-text"],
  "clearTextReporter": {
    "allowColor": true,
    "logTests": true,
    "maxTestsToLog": 5,
    "skipFull": false
  },
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60
  },
  "timeoutMS": 10000,
  "timeoutFactor": 2,
  "dryRunTimeoutMinutes": 2,
  "concurrency": 4,
  "disableBail": false,
  "cleanTempDir": "always",
  "logLevel": "warn"
}
