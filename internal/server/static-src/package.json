{
  "type": "module",
  "scripts": {
    "typecheck": "tsgo -project tsconfig.json",
    "typecheck:tests": "tsgo -project tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check ../..",
    "lint:fix": "eslint . --fix && prettier --write ../..",
    "lint:knip": "knip"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "fast-check": "4.8.0",
    "happy-dom": "20.10.6",
    "html-validate": "11.5.5",
    "knip": "6.24.0",
    "prettier": "3.9.4",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@cplieger/actions": "2.0.6",
    "@cplieger/reactive": "1.2.2",
    "@cplieger/ui-primitives": "2.1.0"
  }
}
